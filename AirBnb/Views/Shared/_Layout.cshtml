<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AirBnb Clone Template</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AirBnb.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="app-header border-bottom">
        <nav class="navbar navbar-expand-lg bg-white">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">AirBnb Clone</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topMenu" aria-controls="topMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="topMenu">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Overview</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Template" asp-action="Index">Sample Page</a></li>
                        <li class="nav-item"><a class="btn btn-sm btn-dark" href="#">Host Setup</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell container-fluid">
        <aside class="app-sidebar">
            <p class="text-uppercase small fw-semibold text-secondary mb-3">Modules</p>
            <nav class="nav flex-column gap-1">
                <a class="nav-link" asp-controller="Home" asp-action="Index">Project Overview</a>
                <a class="nav-link" asp-controller="Template" asp-action="Index">Template Dashboard</a>
                <a class="nav-link" href="#">Users</a>
                <a class="nav-link" href="#">Listings</a>
                <a class="nav-link" href="#">Availability</a>
                <a class="nav-link" href="#">Reservations</a>
                <a class="nav-link" href="#">Payments</a>
                <a class="nav-link" href="#">Reviews</a>
                <a class="nav-link" href="#">Listing Images</a>
            </nav>
        </aside>

        <main role="main" class="app-content">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer border-top text-muted">
        <div class="container-fluid">
            &copy; 2026 - AirBnb Clone Template - All Rights Reserved
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
