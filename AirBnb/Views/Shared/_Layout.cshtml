<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Poyraz Gayrimenkul </title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/AirBnb.styles.css" asp-append-version="true"/>
    <style>
        .app-body {
            background-color: #f8f9fa;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        .app-header {
            z-index: 1030;
        }
        .app-shell {
            display: flex;
            min-height: calc(100vh - 116px);
            padding: 0 !important;
        }
        .app-sidebar {
            width: 260px;
            background-color: #ffffff;
            border-right: 1px solid rgba(0,0,0,0.07);
            padding: 1.5rem 1rem;
            flex-shrink: 0;
        }
        .app-content {
            flex-grow: 1;
            padding: 2rem;
            background-color: #f8f9fa;
            overflow-y: auto;
        }
        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.6rem 1rem;
            color: #495057;
            font-weight: 500;
            font-size: 14px;
            border-radius: 10px;
            transition: all 0.2s ease;
        }
        .sidebar-nav .nav-link:hover {
            background-color: #f1f3f5;
            color: #0d6efd;
        }
        .sidebar-nav .nav-link.active {
            background-color: #e8f0fe;
            color: #0d6efd;
        }
        .app-footer {
            background-color: #ffffff;
            padding: 1rem 2rem;
            font-size: 13px;
        }
    </style>
</head>
<body class="app-body">
    <header class="app-header border-bottom">
        <nav class="navbar navbar-expand-lg bg-white">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Poyraz Gayrimenkul</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topMenu" aria-controls="topMenu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="topMenu">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Genel Bakış</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Template" asp-action="Index">Gösterge Paneli</a></li>
                        <li class="nav-item"><a class="btn btn-sm btn-primary rounded-pill px-3 fw-bold" href="#">Host Setup</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell container-fluid">
        <aside class="app-sidebar">
            <p class="text-uppercase small fw-bold text-secondary mb-3 px-3" style="font-size: 11px; letter-spacing: 0.5px;">Sayfalar</p>
            <nav class="nav flex-column sidebar-nav gap-1">
                <a class="nav-link" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i> Genel Bakış
                </a>
                <a class="nav-link" asp-controller="Template" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Gösterge Paneli
                </a>
                <a class="nav-link" asp-controller="User" asp-action="Index">
                    <i class="bi bi-people-fill"></i> Kullanıcılar
                </a>
                <a class="nav-link" asp-controller="Listing" asp-action="Index">
                    <i class="bi bi-houses-fill"></i> İlanlar
                </a>
                <a class="nav-link" asp-controller="Availability" asp-action="Index">
                    <i class="bi bi-calendar3"></i> Müsaitlik Takvimi
                </a>
                <a class="nav-link" asp-controller="Reservation" asp-action="Index">
                    <i class="bi bi-journal-check"></i> Rezervasyonlar
                </a>
                <a class="nav-link" asp-controller="Payment" asp-action="Index">
                    <i class="bi bi-credit-card-2-front-fill"></i> Ödemeler
                </a>
                <a class="nav-link" asp-controller="Review" asp-action="Index">
                    <i class="bi bi-chat-right-heart-fill"></i> Yorumlar
                </a>
                <hr class="my-2 text-secondary opacity-25">
                <a class="nav-link" asp-controller="Home" asp-action="Privacy">
                    <i class="bi bi-envelope-paper-fill"></i> Gizlilik Sözleşmemiz
                </a>
                <a class="nav-link" asp-controller="Home" asp-action="Contact">
                    <i class="bi bi-envelope-paper-fill"></i> Bizimle İletişime Geçin
                </a>
            </nav>
        </aside>

        <main role="main" class="app-content">
            @if (!(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index"))
            {
                <div class="mb-3 text-start">
                    <a href="/" class="btn btn-sm btn-link text-secondary p-0 text-decoration-none d-inline-flex align-items-center fw-semibold transition-link" style="font-size: 13px;">
                        <i class="bi bi-arrow-left-circle-fill me-2 text-primary fs-5"></i> Genel Bakışa Dön (Ana Sayfa)
                    </a>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="app-footer border-top text-muted">
        <div class="container-fluid">
            &copy; 2026 - Poyraz Gayrimenkul - All Rights Reserved
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>