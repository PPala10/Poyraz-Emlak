@model AirBnb.Data.User

@{
    ViewData["Title"] = "Kullanıcı Kaydı";
}

<div class="container mt-4" style="max-width: 550px;">
    <div class="mb-3 text-start">
        <a href="/User" class="btn btn-sm btn-link text-secondary p-0 text-decoration-none fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Kullanıcı Listesine Dön
        </a>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 p-4">
        <div class="text-center mb-4">
            <i class="bi bi-person-plus-fill text-primary fs-1"></i>
            <h2 class="fw-bold text-dark mt-2">Kullanıcı Ekle</h2>
            <p class="text-muted small">Sisteme yeni bir Admin, Ev Sahibi veya Misafir kaydediyorsunuz.</p>
        </div>

        <form action="/User/Register" method="post">
            <input type="hidden" name="avatar_url" id="selected_avatar" value="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150" />

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Adınız</label>
                    <input type="text" name="fname" class="form-control rounded-3" required>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Soyadınız</label>
                    <input type="text" name="lname" class="form-control rounded-3" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">E-posta Adresi</label>
                <input type="email" name="email" class="form-control rounded-3" placeholder="ornek@email.com" required>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Şifre</label>
                <input type="password" name="password" class="form-control rounded-3" required>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Telefon Numarası</label>
                <input type="tel" name="phone" class="form-control rounded-3" placeholder="+90 555..." required>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">Kullanıcı Rolü</label>
                <select name="role" class="form-select rounded-3" required>
                    <option value="host">Host</option>
                    <option value="guest">Guest</option>
                    <option value="admin">Admin</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary d-block mb-2">Profil Resmi Seçin</label>
                <div class="d-flex flex-wrap justify-content-center gap-2 p-3 bg-light rounded-4 border">
                    <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150" 
                         class="avatar-option rounded-circle border border-3 border-primary cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150')">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=150" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=150')">
                    <img src="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=150" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=150')">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100')">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150')">
                    <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?w=150" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1517841905240-472988babdf9?w=150')">
                    <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=150" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=150')">
                    <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=150" 
                         class="avatar-option rounded-circle border border-3 border-transparent cursor-pointer" 
                         style="width: 52px; height: 52px; object-fit: cover; transition: 0.2s;" 
                         onclick="selectAvatar(this, 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=150')">
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 rounded-pill py-2.5 shadow-sm fw-bold">
                <i class="bi bi-person-plus-fill me-2"></i>Kaydı Tamamla & İlan Eklemeye Geç
            </button>
        </form>
    </div>
</div>

<script>
function selectAvatar(element, url) {
    document.querySelectorAll('.avatar-option').forEach(img => {
        img.classList.remove('border-primary');
        img.classList.add('border-transparent');
    });
    element.classList.remove('border-transparent');
    element.classList.add('border-primary');
    document.getElementById('selected_avatar').value = url;
}
</script>

<style>
.cursor-pointer { cursor: pointer; }
.border-transparent { border-color: transparent !important; }
</style>