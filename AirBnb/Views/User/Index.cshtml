@model IEnumerable<AirBnb.Data.User>

@{
    ViewData["Title"] = "Kayıtlı Kullanıcılar";
}

<div class="container mt-4" style="max-width: 950px;">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div class="text-start">
            <h1 class="h3 fw-bold text-dark mb-0">Sistemdeki Kullanıcılar</h1>
        </div>
        
        <div class="d-flex gap-2">
            <a href="/Listing" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="bi bi-house-fill me-2"></i>İlanları Listele
            </a>
            <a href="/Listing/Create" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-circle-fill me-2"></i>Yeni İlan Ekle
            </a>
            <a href="/User/Register" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-person-plus-fill me-2"></i>Yeni Kullanıcı Ekle
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Profil</th>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th class="pe-4 text-center" style="width: 120px;">Aksiyonlar</th>
                    </tr>
                </thead>
                <tbody class="text-dark">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-people text-muted fs-1 d-block mb-2"></i>
                                Henüz hiç kullanıcı kaydedilmemiş.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">@user.userId</td>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(user.avatar_url) ? "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100" : user.avatar_url)" 
                                         class="rounded-circle object-fit-cover" style="width: 40px; height: 40px;" alt="Avatar">
                                </td>
                                <td class="fw-bold">@user.fname @user.lname</td>
                                <td>@user.email</td>
                                <td class="text-muted small">@user.phone</td>
                                
                                <td>
                                    @if (user.role?.ToLower() == "admin")
                                    {
                                        <span class="badge bg-danger text-white rounded-pill px-2.5 py-1.5 small fw-bold shadow-sm" style="font-size: 11px;">
                                            <i class="bi bi-shield-fill-check me-1"></i>Admin
                                        </span>
                                    }
                                    else if (user.role?.ToLower() == "host")
                                    {
                                        <span class="badge bg-success text-white rounded-pill px-2.5 py-1.5 small fw-bold shadow-sm" style="font-size: 11px;">
                                            <i class="bi bi-house-fill me-1"></i>Host
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary text-white rounded-pill px-2.5 py-1.5 small fw-bold shadow-sm" style="font-size: 11px;">
                                            <i class="bi bi-person-fill me-1"></i>Guest
                                        </span>
                                    }
                                </td>
                                
                                <td>
                                    @if (user.is_verified)
                                    {
                                        <span class="text-success small fw-bold"><i class="bi bi-patch-check-fill me-1"></i>Onaylı</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning small fw-bold"><i class="bi bi-hourglass-split me-1"></i>Beklemede</span>
                                    }
                                </td>
                                
                                <td class="pe-4 text-center text-nowrap">
                                    <a href="/User/Edit/@user.userId" class="btn btn-sm btn-warning text-dark rounded-circle p-0 d-inline-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;" title="Düzenle">
                                        <i class="bi bi-pencil-fill" style="font-size: 13px;"></i>
                                    </a>
                                    
                                    <form action="/User/Delete/@user.userId" method="post" class="d-inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-danger text-white rounded-circle p-0 d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Sil">
                                            <i class="bi bi-x fs-5 fw-bold"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>