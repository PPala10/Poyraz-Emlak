@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold">Kullanıcı Yönetimi</h1>
            <p class="text-muted small mb-0">Sistemde kayıtlı olan tüm ev sahipleri, misafirler ve yöneticilerin listesi.</p>
        </div>
        <a href="/User/Register" class="btn btn-outline-primary rounded-pill px-4 shadow-sm me-2">
            <i class="bi bi-person-plus-fill me-2"></i>Yeni Kullanıcı Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 mb-4 p-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-dark rounded-pill px-3">Tümü (4)</button>
                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3">Ev Sahipleri (Host)</button>
                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3">Misafirler (Guest)</button>
                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3">Yöneticiler (Admin)</button>
            </div>
            <div class="position-relative" style="width: 250px;">
                <input type="text" class="form-control form-control-sm rounded-pill ps-4" placeholder="Kullanıcı ara...">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted small"></i>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-dark">
                <thead class="table-light text-secondary small uppercase fw-bold">
                    <tr>
                        <th class="ps-4">Kullanıcı</th>
                        <th>E-posta</th>
                        <th>Telefon</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">Aksiyon</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&auto=format&fit=crop" class="rounded-circle object-fit-cover" alt="Avatar" width="40" height="40">
                                <div>
                                    <div class="fw-bold">Poyraz Pala</div>
                                    <small class="text-muted">Kayıt: 08.07.2026</small>
                                </div>
                            </div>
                        </td>
                        <td>poyraz.pala@example.com</td>
                        <td>+90 555 123 4567</td>
                        <td><span class="badge bg-danger-subtle text-danger px-2 py-1 rounded-pill small">Admin</span></td>
                        <td><span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill small"><i class="bi bi-patch-check-fill me-1"></i>Onaylı</span></td>
                        <td class="text-end pe-4">
                            <a href="/Users/Edit/1" class="btn btn-sm btn-outline-primary rounded-pill me-1"><i class="bi bi-pencil"></i></a>
                            <button class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>

                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&auto=format&fit=crop" class="rounded-circle object-fit-cover" alt="Avatar" width="40" height="40">
                                <div>
                                    <div class="fw-bold">Ahmet Yılmaz</div>
                                    <small class="text-muted">Kayıt: 05.06.2026</small>
                                </div>
                            </div>
