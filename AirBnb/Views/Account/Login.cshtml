@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giriş Yap - AirBnbClone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f7f7f7; font-family: system-ui, -apple-system, sans-serif; }
        .card-login { border-radius: 16px; border: 1px solid #dddddd; max-width: 420px; width: 100%; }
        .btn-airbnb { background-color: #ff385c; color: white; border: none; font-weight: bold; }
        .btn-airbnb:hover { background-color: #e61e4d; color: white; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 p-3">

    <div class="card card-login bg-white shadow-sm p-4">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock-fill text-danger fs-1"></i>
            <h2 class="h4 fw-bold text-dark mt-2">Hesabınıza Giriş Yapın</h2>
            <p class="text-muted small">Lokal geliştirme paneline erişmek için bilgilerinizi girin.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success rounded-3 p-2.5 small mb-3 fw-bold" role="alert">
                <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger rounded-3 p-2.5 small mb-3 fw-bold" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["ErrorMessage"]
            </div>
        }

        <form action="/Account/Login" method="post">
            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Kullanıcı Adı veya E-posta</label>
                <input type="text" name="username" class="form-control rounded-3" placeholder="Kullanıcı adı veya email..." required />
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">Şifre</label>
                <input type="password" name="password" class="form-control rounded-3" placeholder="••••••••" />
            </div>

            <button type="submit" class="btn btn-airbnb w-100 py-2.5 rounded-3 mb-3">Giriş Yap</button>

            <div class="text-center">
                <span class="text-muted small">Henüz hesabınız yok mu?</span>
                <a href="/Account/Register" class="text-danger small fw-bold text-decoration-none ms-1">Kayıt Ol</a>
            </div>
        </form>
    </div>

</body>
</html>