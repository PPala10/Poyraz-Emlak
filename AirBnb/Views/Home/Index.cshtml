@{
    ViewData["Title"] = "Genel Bakış";
}

<section class="surface-card mb-3">
    <h1 class="h3">Poyraz Gayrimenkul - @(DateTime.UtcNow.AddHours(3).Hour < 18 ? "İyi Günler" : "İyi Akşamlar") Dileriz</h1>
    <p class="text-muted mb-0">
        Hızlı, güvenilir ve ucuz emlağın doğru adresi. Eviniz evimiz, sizler her şeyimizsiniz.
    </p>
</section>

<section class="surface-card mb-3">
    <h2 class="h5 mb-3">Görüntülemek İstediğiniz Alana Tıklayın:</h2>
    <div class="row g-3">
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>Kullanıcılar</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="User" asp-action="Index">Kullanıcıları Görüntüle</a>
        </div>
    </div>        
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>İlanlar</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Listing" asp-action="Index">İlanları Görüntüle</a>
        </div>
    </div>
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>Müsaitlik Takvimi</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Availability" asp-action="Index">Müsaitlik Durumunu Görüntüle</a>
        </div>
    </div>
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>Rezervasyonlar</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Reservation" asp-action="Index">Rezervasyonları Görüntüle</a>
        </div>
    </div>        
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>Ödemeler</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Payment" asp-action="Index">Ödeme İşlemlerini Görüntüle</a>
        </div>
    </div>
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>Yorumlar</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Review" asp-action="Index">Yorumları Görüntüle</a>
        </div>
    </div>
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>İletişim</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Home" asp-action="Contact">Bizimle İletişime Geçin</a>
        </div>
    </div>
    <div class="col-md-10 col-xl-4">
        <div class="border rounded p-3 h-100 d-flex flex-column justify-content-between">
            <span>Gizlilik</span>
            <a class="btn btn-sm btn-outline-dark mt-2" asp-controller="Home" asp-action="Privacy">Gizlilik Sözleşmemizi Okuyun</a>
        </div>
    </div>
    </div>
</section>
