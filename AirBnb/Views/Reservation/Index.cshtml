@model IEnumerable<AirBnb.Data.Reservation>

@{
    ViewData["Title"] = "Rezervasyon Yönetimi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Rezervasyon Listesi</h1>
            <p class="text-muted small mb-0">Sistemdeki aktif ve geçmiş tüm rezervasyonların detaylarını buradan inceleyebilirsiniz.</p>
        </div>
        <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold">Toplam: @Model.Count() Kayıt</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 p-3 small mb-4 fw-bold shadow-sm d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small fw-bold text-uppercase">Rezervasyon Yapan</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Konaklanacak Ev</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Tarih Aralığı</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Süre</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Toplam Tutar</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Durum</th>
                        <th class="pe-4 py-3 text-end text-secondary small fw-bold text-uppercase">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x fs-1"></i>
                                <p class="mt-2 mb-0">Sistemde henüz hiç rezervasyon bulunmuyor.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@item.guest?.avatar_url" class="rounded-circle object-fit-cover" style="width: 40px; height: 40px;" alt="Guest Avatar">
                                        <div>
                                            <h6 class="fw-bold text-dark mb-0">@item.guest?.fname @item.guest?.lname</h6>
                                            <small class="text-muted">@item.guest?.email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@item.listing?.MainImage" class="rounded-2 object-fit-cover" style="width: 40px; height: 40px;" alt="Listing">
                                        <div>
                                            <h6 class="fw-bold text-dark mb-0 text-truncate" style="max-width: 150px;">@item.listing?.title</h6>
                                            <small class="text-muted">@item.listing?.city, @item.listing?.country</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark mb-0">
                                        @item.check_in.ToString("dd MMM yyyy") - @item.check_out.ToString("dd MMM yyyy")
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary px-4 py-2 rounded-pill small fw-bold">
                                        @item.total_nights Gece
                                    </span>
                                    </td>
                                <td>
                                    <span class="fw-bold text-success">@item.total_price.ToString("C")</span>
                                </td>
                                <td>
                                    @if (item.status == "Confirmed" || item.status == "confirmed")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill small fw-bold">Onaylandı</span>
                                    }
                                    else if (item.status == "Cancelled" || item.status == "cancelled")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill small fw-bold">İptal Edildi</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill small fw-bold">@item.status</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (item.status != "Cancelled" && item.status != "cancelled")
                                        {
                                            <a href="/Review/Create?reservationId=@item.reservationId" class="btn btn-sm btn-outline-warning rounded-pill px-3 fw-bold">
                                                <i class="bi bi-star-fill me-1"></i> Yorum Yap
                                            </a>
                                        }
                                        <form action="/Reservation/Cancel" method="post" onsubmit="return confirm('Bu rezervasyonu iptal etmek istediğinize emin misiniz?');" class="d-inline">
                                            <input type="hidden" name="id" value="@item.reservationId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold">İptal Et</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>