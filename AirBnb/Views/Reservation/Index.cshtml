@model IEnumerable<AirBnb.Data.Reservation>

@{
    ViewData["Title"] = "Rezervasyon Yönetimi";
}

<style>
    .table-listing-img {
        width: 48px;
        height: 48px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid rgba(0,0,0,0.08);
    }
    .table-avatar {
        width: 36px;
        height: 36px;
        object-fit: cover;
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.08);
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Rezervasyon Listesi</h1>
            <p class="text-muted small mb-0">Sistemdeki aktif ve geçmiş tüm rezervasyonların detaylarını buradan inceleyebilirsiniz.</p>
        </div>
        <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold">Toplam: @Model.Count() Kayıt</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 p-3 small mb-4 fw-bold shadow-sm d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3 p-3 small mb-4 fw-bold shadow-sm d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small fw-bold text-uppercase">Rezervasyon Yapan</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Konaklanacak Ev</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Tarih Aralığı</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Süre</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Toplam Tutar</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Durum</th>
                        <th class="pe-4 py-3 text-end text-secondary small fw-bold text-uppercase">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x fs-1"></i>
                                <p class="mt-2 mb-0">Henüz hiç rezervasyon kaydı bulunmuyor.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-light text-dark rounded-pill border fw-bold mb-2">#@item.reservationId</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@(string.IsNullOrEmpty(item.guest?.avatar_url) ? "/images/default-avatar.jpg" : item.guest.avatar_url)" class="table-avatar" alt="Avatar">
                                        <div class="fw-bold text-dark">@(item.guest != null ? $"{item.guest.fname} {item.guest.lname}" : "Bilinmiyor")</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(string.IsNullOrEmpty(item.listing?.MainImage) ? "/images/default-listing.jpg" : item.listing.MainImage)" class="table-listing-img" alt="Listing Image">
                                        <div>
                                            <span class="fw-bold text-dark text-truncate d-inline-block" style="max-width: 180px;" title="@item.listing?.title">
                                                @item.listing?.title
                                            </span>
                                            <small class="text-muted d-block" style="font-size: 11px;">@item.listing?.city, @item.listing?.country</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small text-dark fw-semibold">@item.check_in.ToString("dd MMM yyyy") - @item.check_out.ToString("dd MMM yyyy")</div>
                                </td>
                                <td>
                                    <span class="text-secondary small fw-bold">@item.total_nights Gece</span>
                                </td>
                                <td>
                                    <span class="fw-bold text-success">₺@item.total_price.ToString("N0")</span>
                                </td>
                                <td>
                                    @if (item.status == "Confirmed" || item.status == "confirmed")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill small fw-bold">Onaylandı</span>
                                    }
                                    else if (item.status == "Cancelled" || item.status == "cancelled")
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill small fw-bold">İptal Edildi</span>
                                    }
                                    else if (item.status == "Pending" || item.status == "pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill small fw-bold">Ödeme Bekliyor</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded-pill small fw-bold">@item.status</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (item.status == "Confirmed" || item.status == "confirmed")
                                        {
                                            <a href="/Review/Create?reservationId=@item.reservationId" class="btn btn-sm btn-outline-warning rounded-pill px-3 fw-bold">
                                                <i class="bi bi-star-fill me-1"></i> Yorum Yap
                                            </a>
                                        }
                                        @if (item.status != "Confirmed" && item.status != "confirmed" && item.status != "Cancelled" && item.status != "cancelled")
                                        {
                                            <a href="/Payment/CheckOut?reservationId=@item.reservationId" class="btn btn-sm btn-success rounded-pill px-3 fw-bold">
                                                <i class="bi bi-credit-card-fill me-1"></i> Ödeme Yap
                                            </a>
                                        }
                                        <form action="/Reservation/Cancel" method="post" onsubmit="return confirm('İptal etmek istiyor musunuz?');" class="d-inline">
                                            <input type="hidden" name="id" value="@item.reservationId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold">İptal Et</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>