@model IEnumerable<AirBnb.Data.Reservation>

@{
    ViewData["Title"] = "Rezervasyonlar";
}

<div class="container mt-4" style="max-width: 1050px;">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Rezervasyon Yönetimi</h1>
            <p class="text-muted small mb-0">Sistemdeki tüm rezervasyon kayıtlarını buradan inceleyebilir ve yönetebilirsiniz.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Listing" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="bi bi-house-fill me-2"></i>İlanları Listele
            </a>
            <a href="/User" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-people-fill me-2"></i>Kullanıcılar
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small fw-bold">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Misafir</th>
                        <th>İlan</th>
                        <th>Giriş / Çıkış</th>
                        <th>Gece</th>
                        <th>Toplam Tutar</th>
                        <th>Durum</th>
                        <th class="pe-4 text-center" style="width: 100px;">Aksiyonlar</th>
                    </tr>
                </thead>
                <tbody class="text-dark">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x text-muted fs-1 d-block mb-2"></i>
                                Sistemde henüz hiç rezervasyon kaydı bulunmuyor.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var reservation in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">@reservation.reservationId</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@(string.IsNullOrEmpty(reservation.guest?.avatar_url) ? "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150" : reservation.guest.avatar_url)" 
                                             class="rounded-circle object-fit-cover" style="width: 38px; height: 38px;" alt="Avatar">
                                        <span class="fw-bold">@reservation.guest?.fname @reservation.guest?.lname</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-truncate" style="max-width: 180px;">@reservation.listing?.title</div>
                                    <small class="text-muted"><i class="bi bi-geo-alt-fill me-1"></i>@reservation.listing?.city</small>
                                </td>
                                <td class="small fw-semibold">
                                    @reservation.check_in.ToString("dd/MM/yyyy") - @reservation.check_out.ToString("dd/MM/yyyy")
                                </td>
                                <td class="fw-bold text-secondary">@reservation.total_nights</td>
                                <td class="fw-bold text-primary">₺@reservation.total_price.ToString("N0")</td>
                                <td>
                                    @if (reservation.status?.ToLower() == "confirmed")
                                    {
                                        <span class="badge bg-success text-white rounded-pill px-3 py-1.5 small fw-bold shadow-sm" style="font-size: 11px;">
                                            <i class="bi bi-check-circle-fill me-1"></i>Onaylandı
                                        </span>
                                    }
                                    else if (reservation.status?.ToLower() == "pending")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-1.5 small fw-bold shadow-sm" style="font-size: 11px;">
                                            <i class="bi bi-hourglass-split me-1"></i>Beklemede
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary text-white rounded-pill px-3 py-1.5 small fw-bold shadow-sm" style="font-size: 11px;">
                                            İptal Edildi
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 text-center text-nowrap">
                                    <form action="/Reservation/Cancel/@reservation.reservationId" method="post" onsubmit="return confirm('Bu rezervasyonu iptal etmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold" style="font-size: 12px;">
                                            İptal Et
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>