@model AirBnb.Models.Dashboard
@{
    ViewData["Title"] = "Gösterge Paneli";
}

<style>
    .hover-card {
        transition: all 0.3s cubic-bezier(.25, .8, .25, 1);
        border: 1px solid rgba(0, 0, 0, .06) !important;
    }
    .hover-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.08) !important;
    }
    .icon-box-dash {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }
    .table-avatar {
        width: 32px;
        height: 32px;
        object-fit: cover;
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.1);
    }
    .table-listing-img {
        width: 40px;
        height: 40px;
        object-fit: cover;
        border-radius: 8px;
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h1 class="h3 mb-1 fw-bold text-dark"><i class="bi bi-speedometer2 text-primary me-2"></i>Gösterge Paneli</h1>
        <p class="text-muted small mb-0">Aktif tüm gelişmeleri, platform performansını ve son işlemleri buradan anlık izleyebilirsiniz.</p>
    </div>
    <a href="/Listing/Create" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">
        <i class="bi bi-plus-circle-fill me-2"></i>Yeni İlan Ekle
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card hover-card h-100 p-3 bg-white shadow-sm rounded-4 border-0 d-flex flex-row align-items-center gap-3">
            <div class="icon-box-dash bg-primary-subtle text-primary">
                <i class="bi bi-house-door-fill fs-4"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Toplam İlan Sayısı</p>
                <p class="h3 mb-0 fw-bold text-dark">@Model.totalListing</p>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card hover-card h-100 p-3 bg-white shadow-sm rounded-4 border-0 d-flex flex-row align-items-center gap-3">
            <div class="icon-box-dash bg-success-subtle text-success">
                <i class="bi bi-people-fill fs-4"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Kayıtlı Ev Sahibi</p>
                <p class="h3 mb-0 fw-bold text-dark">@Model.totalUser</p>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card hover-card h-100 p-3 bg-white shadow-sm rounded-4 border-0 d-flex flex-row align-items-center gap-3">
            <div class="icon-box-dash bg-warning-subtle text-warning fw-bold fs-4">
                ₺
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Ortalama Gece Fiyatı</p>
                <p class="h3 mb-0 fw-bold text-dark">₺@Model.averageListing.ToString("N0")</p>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card hover-card h-100 p-3 bg-white shadow-sm rounded-4 border-0 d-flex flex-row align-items-center gap-3">
            <div class="icon-box-dash bg-info-subtle text-info">
                <i class="bi bi-check-circle-fill fs-4"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Aktif Canlı İlanlar</p>
                <p class="h3 mb-0 fw-bold text-dark">@Model.activeListingNum</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
            <h2 class="h5 mb-3 fw-bold text-dark d-flex align-items-center gap-2">
                <i class="bi bi-clock-history text-secondary"></i>Son Eklenen İlanlar
            </h2>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small fw-bold">
                        <tr>
                            <th>İlan Bilgisi</th>
                            <th>Şehir</th>
                            <th>Gecelik Fiyat</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark">
                        @if (!Model.latestListings.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted small">
                                    <i class="bi bi-house-x d-block fs-3 mb-1"></i>
                                    Henüz ilan kaydı yok.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var listing in Model.latestListings)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="@(string.IsNullOrEmpty(listing.MainImage) ? "/images/default-listing.jpg" : listing.MainImage)" class="table-listing-img" alt="Listing Image">
                                            <span class="fw-bold text-dark text-truncate" style="max-width: 140px;" title="@listing.title">@listing.title</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-secondary small">@listing.city</span>
                                    </td>
                                    <td class="fw-bold text-primary">₺@listing.price_per_night.ToString("N0")</td>
                                    <td>
                                        @if (listing.is_active)
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-2.5 py-1.5 fw-bold small">Canlıda</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2.5 py-1.5 fw-bold small">Pasif</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100">
            <h2 class="h5 mb-3 fw-bold text-dark d-flex align-items-center gap-2">
                <i class="bi bi-calendar-check text-secondary"></i>Son Rezervasyonlar
            </h2>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small fw-bold">
                        <tr>
                            <th>Misafir</th>
                            <th>İlan Başlığı</th>
                            <th>Toplam Tutar</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark">
                        @if (!Model.latestsReservations.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted small">
                                    <i class="bi bi-calendar-x d-block fs-3 mb-1"></i>
                                    Henüz rezervasyon kaydı bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var reservation in Model.latestsReservations)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="@(string.IsNullOrEmpty(reservation.guest?.avatar_url) ? "/images/default-avatar.jpg" : reservation.guest.avatar_url)" class="table-avatar" alt="Avatar">
                                            <span class="fw-bold text-dark small">
                                                @(reservation.guest != null ? $"{reservation.guest.fname} {reservation.guest.lname}" : "Bilinmiyor")
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-secondary small text-truncate d-inline-block" style="max-width: 140px;" title="@reservation.listing?.title">
                                            @reservation.listing?.title
                                        </span>
                                    </td>
                                    <td class="fw-bold text-primary">₺@reservation.total_price.ToString("N0")</td>
                                    <td>
                                        @if (reservation.status?.ToLower() == "confirmed")
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-2.5 py-1.5 fw-bold small">Onaylandı</span>
                                        }
                                        else if (reservation.status?.ToLower() == "cancelled")
                                        {
                                            <span class="badge bg-danger-subtle text-danger rounded-pill px-2.5 py-1.5 fw-bold small">İptal Edildi</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning-subtle text-warning rounded-pill px-2.5 py-1.5 fw-bold small">Beklemede</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>