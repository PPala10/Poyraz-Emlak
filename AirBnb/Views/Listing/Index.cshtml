@model IEnumerable<AirBnb.Data.Listing>

@{
    ViewData["Title"] = "İlanlar";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold text-dark mb-0">Gezilecek Harika Yerler</h1>
        <div>
            @if (User.IsInRole("Admin"))
            {
                <a href="/User" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm me-2">
                    <i class="bi bi-people-fill me-2"></i>Kullanıcıları Listele
                </a>
                <a href="/Account/Register" class="btn btn-outline-primary rounded-pill px-4 shadow-sm me-2">
                    <i class="bi bi-person-plus-fill me-2"></i>Yeni Kullanıcı Ekle
                </a>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Host"))
            {
                <a href="/Listing/Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-circle-fill me-2"></i>Yeni İlan Ekle
                </a>
            }
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        
        @if (!Model.Any())
        {
            <div class="col-12 text-center my-5">
                <i class="bi bi-house-exclamation text-muted fs-1"></i>
                <p class="text-muted mt-2">Henüz veritabanında ilan bulunmuyor.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm surface-card rounded-4 position-relative overflow-hidden transition-card">
                        
                        @if (User.IsInRole("Admin") || User.IsInRole("Host"))
                        {
                            <form action="/Listing/Delete/@item.listId" method="post" onsubmit="return confirm('Bu ilanı yayından kaldırmak istediğinize emin misiniz?');" class="position-absolute" style="top: 12px; left: 12px; z-index: 10;">
                                <button type="submit" class="btn btn-danger rounded-circle p-0 d-inline-flex align-items-center justify-content-center shadow" style="width: 36px; height: 36px; border: 2px solid white;" title="İlanı Sil">
                                    <i class="bi bi-x-lg" style="font-size: 14px; -webkit-text-stroke: 1px;"></i>
                                </button>
                            </form>

                            <a href="/Listing/Edit/@item.listId" class="btn btn-warning text-dark rounded-circle p-0 d-inline-flex align-items-center justify-content-center shadow position-absolute" style="width: 36px; height: 36px; top: 12px; right: 12px; z-index: 10; border: 2px solid white;" title="İlanı Düzenle">
                                <i class="bi bi-pencil-fill" style="font-size: 14px;"></i>
                            </a>
                        }

                        <img src="@item.MainImage" 
                             class="card-img-top object-fit-cover rounded-top-4" 
                             alt="Property Image" 
                             style="height: 200px; @(!item.is_active ? "filter: grayscale(1) opacity(0.5);" : "")">
                        
                        <div class="card-body px-3 pt-3 pb-3 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="card-title text-dark fw-bold mb-0 text-truncate" style="max-width: 80%;">@item.title</h6>
                                    <span class="text-sm text-muted fw-semibold"><i class="bi bi-star-fill text-warning me-1"></i>4.9</span>
                                </div>
                                
                                <p class="card-text text-muted small mb-1"><i class="bi bi-geo-alt-fill me-1" style="font-size: 11px;"></i>@item.city, @item.country</p>
                                
                                <p class="card-text text-primary small mb-3">
                                    <i class="bi bi-person-circle me-1"></i>Host: @(item.host != null ? $"{item.host.fname} {item.host.lname}" : "Bilinmiyor")
                                </p>
                            </div>
                            
                            <div class="pt-2 border-top">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    @if (item.is_active)
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill small fw-bold">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-2 py-1 rounded-pill small fw-bold">Pasif</span>
                                    }
                                    <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded-pill small fw-semibold" style="font-size: 11px;">@item.property_type</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-secondary small">Gecelik Fiyat</span>
                                    <span class="text-dark fw-bold h5 mb-0">₺@item.price_per_night.ToString("N0")</span>
                                </div>
                                
                                <a href="/Listing/Detail/@item.listId" class="btn btn-outline-primary w-100 rounded-pill py-2 small fw-bold shadow-sm transition-button mt-3">
                                    <i class="bi bi-eye-fill me-2"></i>Detayları İncele
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
.transition-card {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}
.transition-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important;
}
.transition-button {
    transition: all 0.2s ease;
}
.transition-button:hover {
    background-color: var(--bs-primary);
    color: white;
}
</style>