@model AirBnb.Data.Listing

@{
    ViewData["Title"] = "İlan Düzenle (Admin Paneli)";
}

<div class="container mt-5" style="max-width: 550px;">
    <div class="mb-3">
        <a href="/Listing" class="btn btn-sm btn-link text-secondary p-0 text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> İlanlar Listesine Dön
        </a>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 p-4">
        <div class="text-center mb-4">
            <i class="bi bi-house-gear-fill text-warning fs-1"></i>
            <h2 class="fw-bold text-dark mt-2">İlan Bilgilerini Düzenle</h2>
            <p class="text-muted small">ID: @Model.listId numaralı ilanın verilerini güncelliyorsunuz.</p>
        </div>

        <form action="/Listing/Edit" method="post">
            <input type="hidden" name="listId" value="@Model.listId" />

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">İlan Başlığı</label>
                <input type="text" name="title" value="@Model.title" class="form-control rounded-3" required>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Açıklama</label>
                <textarea name="description" class="form-control rounded-3" rows="3" required>@Model.description</textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label small fw-bold text-secondary">Şehir</label>
                    <input type="text" name="city" value="@Model.city" class="form-control rounded-3" required>
                </div>
                <div class="col-6">
                    <label class="form-label small fw-bold text-secondary">Ülke</label>
                    <input type="text" name="country" value="@Model.country" class="form-control rounded-3" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Gecelik Fiyat (₺)</label>
                <input type="number" name="price_per_night" value="@Model.price_per_night" class="form-control rounded-3" required>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">Ev Sahibi Değiştir</label>
                <select name="hostId" class="form-select rounded-3" required>
                    @if (ViewBag.users != null)
                    {
                        foreach (var user in (List<AirBnb.Data.User>)ViewBag.users)
                        {
                            <option value="@user.userId" selected="@(user.userId == Model.hostId)">@user.fname @user.lname (@user.email)</option>
                        }
                    }
                </select>
            </div>
            
            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary">Ev Tipi Değiştir</label>
                <select name="property_type" class="form-select rounded-3" required>
                    <option value="Apartman Dairesi" selected="@(Model.property_type == "Apartman Dairesi")">Apartman Dairesi</option>
                    <option value="Villa" selected="@(Model.property_type == "Villa")">Lüks Villa</option>
                    <option value="Dağ Evi" selected="@(Model.property_type == "Dağ Evi")">Otandik Dağ Evi</option>
                    <option value="Stüdyo" selected="@(Model.property_type == "Stüdyo")">Modern Stüdyo Daire</option>
                </select>
            </div>

            <button type="submit" class="btn btn-warning text-dark w-100 rounded-pill py-2.5 fw-bold shadow-sm">
                <i class="bi bi-save2-fill me-2"></i>İlan Değişikliklerini Kaydet
            </button>
        </form>
    </div>
</div>