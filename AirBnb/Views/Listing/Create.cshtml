@model AirBnb.Data.Listing

@{
    ViewData["Title"] = "Yeni İlan Ekle";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="mb-3">
        <a href="/Listing" class="btn btn-sm btn-link text-secondary p-0 text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> İlan Listesine Dön
        </a>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 p-4 mb-4">
        <h1 class="h3 fw-bold text-dark mb-1">Mekanınızı Veritabanına Dahil Edin</h1>
    </div>

    <div class="card border-0 shadow-sm surface-card rounded-4 p-4">
        <form action="/Listing/Create" method="post">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label small fw-bold text-secondary">İlan Başlığı</label>
                    <input type="text" name="title" class="form-control rounded-3" placeholder="Örn: Deniz Manzaralı Taş Ev" required>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-bold text-secondary">Açıklama</label>
                    <textarea name="description" class="form-control rounded-3" rows="4" placeholder="Mekanınızı detaylıca anlatın..." required></textarea>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Şehir</label>
                    <input type="text" name="city" class="form-control rounded-3" placeholder="Örn: Balıkesir" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Ülke</label>
                    <input type="text" name="country" class="form-control rounded-3" placeholder="Örn: Türkiye" required>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-bold text-secondary">Açık Adres</label>
                    <input type="text" name="address" class="form-control rounded-3" placeholder="Sokak, No, Daire..." required>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Konaklama Tipi</label>
                    <select name="property_type" class="form-select rounded-3">
                        <option value="Ev">Müstakil Ev</option>
                        <option value="Taş Ev">Tarihi Taş Ev</option>
                        <option value="Bungalov">Bungalov</option>
                        <option value="Villa">Villa</option>
                        <option value="Oda">Özel Oda</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label small fw-bold text-secondary">Gecelik Fiyat (₺)</label>
                    <input type="number" name="price_per_night" class="form-control rounded-3" step="0.01" required>                
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary">Oda Sayısı</label>
                    <input type="number" name="room_count" class="form-control rounded-3" value="1" min="1" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary">Banyo Sayısı</label>
                    <input type="number" name="bathroom_count" class="form-control rounded-3" value="1" min="1" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary">Maksimum Misafir</label>
                    <input type="number" name="max_guests" class="form-control rounded-3" value="2" min="1" required>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-bold text-secondary">Sunulan İmkanlar (Virgülle ayırın)</label>
                    <input type="text" name="amenities" class="form-control rounded-3" placeholder="Wi-Fi, Havuz, Klima, Otopark">
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                <a href="/Listing" class="btn btn-outline-secondary rounded-pill px-4">İptal</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">İlanı Kaydet</button>
            </div>
        </form>
    </div>
</div>