@model AirBnb.Data.Listing

@{
    ViewData["Title"] = "Yeni İlan Ekle";
}

<div class="container mt-4" style="max-width: 750px;">
    <div class="card border-0 shadow-sm surface-card rounded-4 p-4 bg-white">
        <form action="/Listing/Create" method="post">
            
            <div class="mb-3">
                <label class="form-label fw-bold small text-secondary">Ev Sahibi</label>
                <select name="hostId" class="form-select rounded-3" required>
                    <option value="">-- Ev Sahibi Seçiniz --</option>
                    @if (ViewBag.Hosts != null)
                    {
                        var hostList = ViewBag.Hosts as List<AirBnb.Data.User>;
                        if (hostList != null && hostList.Any())
                        {
                            foreach (var host in hostList)
                            {
                                <option value="@host.userId">@host.fname @host.lname</option>
                            }
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold small text-secondary">İlan Başlığı</label>
                <input type="text" name="title" class="form-control rounded-3" placeholder="İlanınıza şık bir başlık yazın..." required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold small text-secondary">Açıklama</label>
                <textarea name="description" class="form-control rounded-3" rows="4" placeholder="Mekanınızı detaylıca anlatın..." required></textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-bold small text-secondary">Şehir</label>
                    <input type="text" name="city" class="form-control rounded-3" placeholder="Örn: Balıkesir" required>
                </div>
                <div class="col-6">
                    <label class="form-label fw-bold small text-secondary">Ülke</label>
                    <input type="text" name="country" class="form-control rounded-3" placeholder="Örn: Türkiye" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold small text-secondary">Açık Adres</label>
                <textarea name="address" class="form-control rounded-3" rows="2" placeholder="Sokak, No, Daire..." required></textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-bold small text-secondary">Konaklama Türü</label>
                    <select name="property_type" class="form-select rounded-3" required>
                        <option value="">-- Seçiniz --</option>
                        <option value="Bungalov">Bungalov</option>
                        <option value="Villa">Villa</option>
                        <option value="Dağ Evi">Dağ Evi</option>
                        <option value="Taş Ev">Taş Ev</option>
                        <option value="Stüdyo">Stüdyo</option>
                        <option value="Apartman Dairesi">Apartman Dairesi</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label fw-bold small text-secondary">Gecelik Fiyat (₺)</label>
                    <input type="number" name="price_per_night" class="form-control rounded-3" required>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-4">
                    <label class="form-label fw-bold small text-secondary">Oda Sayısı</label>
                    <input type="number" name="room_count" class="form-control rounded-3" value="1" min="1" required>
                </div>
                <div class="col-4">
                    <label class="form-label fw-bold small text-secondary">Banyo Sayısı</label>
                    <input type="number" name="bathroom_count" class="form-control rounded-3" value="1" min="1" required>
                </div>
                <div class="col-4">
                    <label class="form-label fw-bold small text-secondary">Maksimum Misafir</label>
                    <input type="number" name="max_guests" class="form-control rounded-3" value="2" min="1" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small text-secondary">Sunulan İmkanlar (Virgülle ayırın)</label>
                <input type="text" name="amenities" class="form-control rounded-3" placeholder="Wi-Fi, Havuz, Klima, Otopark">
            </div>

            <div class="bg-light rounded-4 p-3 mb-4">
                <h6 class="fw-bold text-dark mb-3 small text-uppercase"><i class="bi bi-calendar3 me-2 text-primary"></i>İlk Müsaitlik Takvimi Aktivasyonu</h6>
                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label small text-muted fw-semibold">Giriş Yapılabilecek İlk Tarih</label>
                        <input type="date" name="availability_start" class="form-control rounded-3" required>
                    </div>
                    <div class="col-6">
                        <label class="form-label small text-muted fw-semibold">Giriş Yapılabilecek Son Tarih</label>
                        <input type="date" name="availability_end" class="form-control rounded-3" required>
                    </div>
                </div>
            </div>

            <input type="hidden" name="is_active" value="true"/>

            <div class="d-flex gap-2 justify-content-end border-top pt-3">
                <a href="/Listing" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold small">İptal</a>
                <button type="submit" class="btn btn-primary rounded-pill px-4 py-2 fw-bold small">İlanı Kaydet</button>
            </div>
        </form>
    </div>
</div>