@model AirBnb.Data.Listing

@{
    ViewData["Title"] = Model.title + " - İlan Detayı";
    var propertyImages = AirBnb.Controllers.ListingController.GetImageGallery(Model.property_type);
    var mainImage = propertyImages.FirstOrDefault() ?? "https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=1200";
    
    string todayDate = DateTime.Today.ToString("yyyy-MM-dd");
    string nextWeekDate = DateTime.Today.AddDays(7).ToString("yyyy-MM-dd");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">@Model.title</h1>
            <p class="text-muted small mb-0">
                <i class="bi bi-geo-alt-fill text-danger me-1"></i>@Model.city, @Model.country 
                <span class="badge bg-secondary-subtle text-secondary ms-2">@Model.property_type</span>
            </p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-dark rounded-pill px-3"><i class="bi bi-share me-1"></i> Paylaş</button>
            <button class="btn btn-sm btn-outline-success rounded-pill px-3"><i class="bi bi-heart me-1"></i> Favori</button>
        </div>
    </div>

    <div class="row g-2 mb-4 rounded-4 overflow-hidden shadow-sm" style="height: 420px;">
        <div class="col-md-8 h-100">
            <img src="@mainImage" class="w-100 h-100 object-fit-cover" alt="Main Image">
        </div>
        <div class="col-md-4 d-flex flex-column gap-2 h-100">
            @foreach (var imageUrl in propertyImages.Skip(1).Take(3))
            {
                <div class="flex-grow-1 overflow-hidden" style="height: 134px;">
                    <img src="@imageUrl" class="w-100 h-100 object-fit-cover" alt="Gallery Image">
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm surface-card rounded-4 p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center pb-3 border-bottom mb-3">
                    <div>
                        <h4 class="h5 fw-bold text-dark mb-1">
                            Ev Sahibi: @(Model.host != null ? $"{Model.host.fname} {Model.host.lname}" : "Sistem Yöneticisi")
                        </h4>
                        <p class="text-muted small mb-0">4 misafir · 2 yatak odası · 2 yatak · 1 banyo</p>
                    </div>
                    <img src="@(Model.host != null && !string.IsNullOrEmpty(Model.host.avatar_url) ? Model.host.avatar_url : "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150")" 
                         class="rounded-circle object-fit-cover" width="55" height="55" alt="Ev Sahibi Profil">
                </div>

                <div class="mb-4">
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <i class="bi bi-door-open fs-4 text-dark"></i>
                        <div>
                            <h6 class="fw-bold text-dark mb-0">Kendi kendinize giriş</h6>
                            <small class="text-muted">Akıllı kilit kullanarak kapıyı kendiniz açabilirsiniz.</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <i class="bi bi-geo-fill fs-4 text-dark"></i>
                        <div>
                            <h6 class="fw-bold text-dark mb-0">Harika konum</h6>
                            <small class="text-muted">Son gelen misafirlerin %95'i bu konuma 5 yıldız verdi.</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3">
                        <i class="bi bi-calendar-check fs-4 text-dark"></i>
                        <div>
                            <h6 class="fw-bold text-dark mb-0">Check-in tarihinden 3 gün öncesine kadar ücretsiz iptal</h6>
                            <small class="text-muted">Planlarınız değişirse tam iade alabilirsiniz.</small>
                        </div>
                    </div>
                </div>

                <hr class="text-muted opacity-25">

                <h5 class="fw-bold text-dark mb-3">Bu mekan hakkında</h5>
                <p class="text-secondary line-height-lg" style="white-space: pre-line;">
                    @Model.description
                </p>

                <hr class="text-muted opacity-25">

                <h5 class="fw-bold text-dark mb-3">Konaklama yerinin sunduğu imkanlar</h5>
                <div class="row g-2">
                    <div class="col-md-6"><i class="bi bi-wifi me-2 text-success"></i> Kesintisiz Wi-Fi (Fiber)</div>
                    <div class="col-md-6"><i class="bi bi-p-circle me-2 text-success"></i> Ücretsiz otopark</div>
                    <div class="col-md-6"><i class="bi bi-water me-2 text-success"></i> Özel Havuz</div>
                    <div class="col-md-6"><i class="bi bi-snow me-2 text-success"></i> Klima</div>
                    <div class="col-md-6"><i class="bi bi-tv me-2 text-success"></i> 55" 4K Smart TV</div>
                    <div class="col-md-6"><i class="bi bi-wind me-2 text-success"></i> Saç kurutma makinesi</div>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm surface-card rounded-4 p-4">
                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-star-fill text-warning me-1"></i> 4.9 · 2 Yorum</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <strong class="text-dark">Ahmet Y.</strong>
                                <span class="text-warning small"><i class="bi bi-star-fill"></i> 5</span>
                            </div>
                            <p class="text-muted small mb-0">"Hayatımda kaldığım en huzurlu yerdi. Ev sahibi çok ilgili, her şeyle nizamîce ilgilendi."</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <strong class="text-dark">Elif K.</strong>
                                <span class="text-warning small"><i class="bi bi-star-fill"></i> 5</span>
                            </div>
                            <p class="text-muted small mb-0">"Konumu çok iyi, temizlik kusursuzdu. Tekrar gelmeyi kesinlikle düşünüyoruz."</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-lg surface-card rounded-4 p-4 sticky-top" style="top: 24px; z-index: 5;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fs-4 text-dark fw-bold">₺@Model.price_per_night.ToString("N0") <span class="fw-normal text-muted small">/ gece</span></span>
                    <span class="small text-dark fw-bold"><i class="bi bi-star-fill text-warning me-1"></i>4.9</span>
                </div>

                <form action="/Reservation/Book" method="post">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger rounded-3 p-2 small mb-3 fw-bold d-flex align-items-center gap-2 shadow-sm" role="alert">
                            <i class="bi bi-exclamation-triangle-fill fs-6"></i>
                            <span>@TempData["ErrorMessage"]</span>
                        </div>
                    }
                    <input type="hidden" name="listingId" value="@Model.listId"/>

                    <div class="border rounded-3 mb-3 overflow-hidden">
                        <div class="row g-0 border-bottom">
                            <div class="col-6 border-end p-2">
                                <label class="d-block text-uppercase text-muted fw-bold" style="font-size: 10px;">Giriş Tarihi</label>
                                <input type="date" id="checkin-date" name="checkin_date" class="form-control form-control-sm border-0 p-0 text-dark bg-transparent" value="@todayDate" min="@todayDate" required>
                            </div>
                            <div class="col-6 p-2">
                                <label class="d-block text-uppercase text-muted fw-bold" style="font-size: 10px;">Çıkış Tarihi</label>
                                <input type="date" id="checkout-date" name="checkout_date" class="form-control form-control-sm border-0 p-0 text-dark bg-transparent" value="@nextWeekDate" required>
                            </div>
                        </div>
                        <div class="p-2">
                            <label class="d-block text-uppercase text-muted fw-bold" style="font-size: 10px;">Rezervasyon Yapacak Misafir</label>
                            <select name="guestId" class="form-select form-select-sm border-0 p-0 text-dark bg-transparent" required>
                                <option value="">-- Misafir Seçin --</option>
                                @if (ViewBag.guests != null)
                                {
                                    foreach (var guest in (List<AirBnb.Data.User>)ViewBag.guests)
                                    {
                                        <option value="@guest.userId">@guest.fname @guest.lname</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <button type="submit" id="btn-reserve" class="btn btn-primary btn-lg w-100 rounded-pill fs-6 shadow-sm fw-bold mb-3">
                        Rezervasyon Yap
                    </button>

                    <p class="text-center text-muted small mb-3">Henüz sizden tahsilat yapılmayacak</p>

                    <div class="small text-secondary mb-2 d-flex justify-content-between">
                        <span id="calc-breakdown" class="text-decoration-underline">₺@Model.price_per_night.ToString("N0") x 7 gece</span>
                        <span id="base-total-display" class="text-dark">₺0</span>
                    </div>
                    <div class="small text-secondary mb-3 d-flex justify-content-between">
                        <span class="text-decoration-underline">Poyraz Hizmet Bedeli</span>
                        <span class="text-dark">₺450</span>
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="fw-bold text-dark d-flex justify-content-between fs-5">
                        <span>Toplam</span>
                        <span id="grand-total-display" class="text-primary">₺0</span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const pricePerNight = @Model.price_per_night;
    const serviceFee = 450;
    
    const checkinInput = document.getElementById("checkin-date");
    const checkoutInput = document.getElementById("checkout-date");
    
    const calcBreakdown = document.getElementById("calc-breakdown");
    const baseTotalDisplay = document.getElementById("base-total-display");
    const grandTotalDisplay = document.getElementById("grand-total-display");
    const submitBtn = document.getElementById("btn-reserve");

    function updatePrice() {
        const date1 = new Date(checkinInput.value);
        const date2 = new Date(checkoutInput.value);
        
        if (isNaN(date1) || isNaN(date2)) return;

        const timeDiff = date2.getTime() - date1.getTime();
        const days = Math.ceil(timeDiff / (1000 * 3600 * 24));

        if (days <= 0) {
            calcBreakdown.innerHTML = '<span class="text-danger fw-bold">Geçersiz Tarih Aralığı!</span>';
            baseTotalDisplay.innerText = "₺0";
            grandTotalDisplay.innerText = "₺0";
            submitBtn.disabled = true;
            return;
        }

        submitBtn.disabled = false;
        
        const baseTotal = days * pricePerNight;
        const grandTotal = baseTotal + serviceFee;

        calcBreakdown.innerText = `₺${pricePerNight.toLocaleString('tr-TR')} x ${days} gece`;
        baseTotalDisplay.innerText = `₺${baseTotal.toLocaleString('tr-TR')}`;
        grandTotalDisplay.innerText = `₺${grandTotal.toLocaleString('tr-TR')}`;
    }

    checkinInput.addEventListener("change", updatePrice);
    checkoutInput.addEventListener("change", updatePrice);

    updatePrice();
});
</script>