@model IEnumerable<AirBnb.Data.Review>

@{
    ViewData["Title"] = "Yorum ve Değerlendirme Yönetimi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Değerlendirme ve Yorum Yönetimi</h1>
            <p class="text-muted small mb-0">Platform genelindeki tüm kullanıcı yorumlarını ve puanlarını buradan inceleyebilirsiniz.</p>
        </div>
        <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold">Toplam: @Model.Count() Yorum</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 p-3 small mb-4 fw-bold shadow-sm d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                <tr>
                    <th class="ps-4 py-3 text-secondary small fw-bold text-uppercase">Yazar (Misafir)</th>
                    <th class="py-3 text-secondary small fw-bold text-uppercase">İlgili İlan</th>
                    <th class="py-3 text-secondary small fw-bold text-uppercase">Puan (Yıldız)</th>
                    <th class="py-3 text-secondary small fw-bold text-uppercase" style="width: 35%;">Yorum</th>
                    <th class="py-3 text-secondary small fw-bold text-uppercase">Rezervasyon / Tarih</th>
                    <th class="pe-4 py-3 text-end text-secondary small fw-bold text-uppercase">İşlemler</th>
                </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-chat-square-text fs-1"></i>
                            <p class="mt-2 mb-0">Sistemde henüz hiç yorum bulunmuyor.</p>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var review in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@review.reviewer?.avatar_url" class="rounded-circle object-fit-cover" style="width: 40px; height: 40px;" alt="Avatar">
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0">@review.reviewer?.fname @review.reviewer?.lname</h6>
                                        <small class="text-muted">@review.reviewer?.email</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@review.listing?.MainImage" class="rounded-2 object-fit-cover" style="width: 40px; height: 40px;" alt="Listing">
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0 text-truncate" style="max-width: 150px;">@review.listing?.title</h6>
                                        <small class="text-muted">@review.listing?.city, @review.listing?.country</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="text-warning text-nowrap">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.rating)
                                        {
                                            <i class="bi bi-star-fill small"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star small"></i>
                                        }
                                    }
                                </div>
                            </td>
                            <td>
                                <p class="text-secondary mb-0 small text-wrap" style="max-height: 60px; overflow-y: auto;">
                                    @review.comment
                                </p>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark rounded-pill fw-bold border mb-1">#@review.reservationId</span>
                                <div class="text-muted small" style="font-size: 11px;">@review.created_at.ToString("dd MMM yyyy HH:mm")</div>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Listing/Detail/@review.listingId" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold">
                                        <i class="bi bi-eye me-1"></i>İlana Git
                                    </a>
                                    <form action="/Review/Delete" method="post" onsubmit="return confirm('Bu yorumu sistemden tamamen silmek istediğinize emin misiniz');" class="d-inline">
                                        <input type="hidden" name="id" value="@review.reviewId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold">
                                            <i class="bi bi-trash3-fill me-1"></i>Kaldır
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        }
                        }
                        </tbody>
            </table>
        </div>
    </div>
</div>
