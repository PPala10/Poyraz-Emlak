@model AirBnb.Data.Reservation

@{
    ViewData["Title"] = "Deneyimi Değerlendir";
}

<div class="container mt-4" style="max-width: 650px;">
    <div class="mb-3 text-start">
        <a href="/Reservation" class="btn btn-sm btn-link text-secondary p-0 text-decoration-none fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Rezervasyonlarıma Dön
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="p-4 bg-light border-bottom d-flex align-items-center gap-3">
            <img src="@Model.listing?.MainImage" class="rounded-3 object-fit-cover" style="width: 70px; height: 70px;" alt="Listing">
            <div>
                <span class="badge bg-primary-subtle text-primary small fw-bold mb-1">Rezervasyon #@Model.reservationId</span>
                <h5 class="fw-bold text-dark mb-0">@Model.listing?.title</h5>
                <p class="text-muted small mb-0">@Model.listing?.city, @Model.listing?.country • @Model.check_in.ToString("dd MMM") - @Model.check_out.ToString("dd MMM yyyy")</p>
            </div>
        </div>

        <div class="card-body p-4">
            <h4 class="fw-bold text-dark text-center mb-1">Konaklamanız Nasıl Geçti?</h4>
            <p class="text-muted small text-center mb-4">Deneyimlerinizi paylaşarak hem ev sahibine geri bildirimde bulunun hem de diğer misafirlere yol gösterin.</p>

            <form action="/Review/Create" method="post">
                <input type="hidden" name="reservationId" value="@Model.reservationId" />

                <div class="mb-4 text-center">
                    <label class="form-label d-block small fw-bold text-secondary mb-2">Puanınız (Yıldız)</label>
                    <div class="d-flex justify-content-center gap-2">
                        <select name="rating" class="form-select rounded-3 text-center fw-bold" style="max-width: 250px;" required>
                            <option value="5">⭐⭐⭐⭐⭐ (5 - Mükemmel)</option>
                            <option value="4">⭐⭐⭐⭐ (4 - Çok İyi)</option>
                            <option value="3">⭐⭐⭐ (3 - Ortalama)</option>
                            <option value="2">⭐⭐ (2 - Kötü)</option>
                            <option value="1">⭐ (1 - Çok Kötü)</option>
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-secondary">Yorumunuz</label>
                    <textarea name="comment" class="form-control rounded-4 p-3" rows="5" placeholder="Evin temizliği, konumu ve ev sahibinin iletişimi nasıldı? Detaylıca yazın..." required></textarea>
                </div>

                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2.5 shadow-sm fw-bold">
                    <i class="bi bi-send-fill me-2"></i>Değerlendirmeyi Gönder & Yayınla
                </button>
            </form>
        </div>
    </div>
</div>